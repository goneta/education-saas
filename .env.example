APP_ENV=production
DATABASE_URL=postgresql+psycopg2://education:change-me@db:5432/education_saas
CORS_ALLOWED_ORIGINS=https://app.example.com
JWT_SECRET_KEY=change-me-with-a-long-random-secret
FIELD_ENCRYPTION_KEY=

# Security controls
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=60
MAX_REQUEST_BODY_BYTES=2097152
SESSION_IDLE_TIMEOUT_MINUTES=30

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ORANGE_SMS_URL=
ORANGE_SMS_TOKEN=
ORANGE_SMS_SENDER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_FROM_EMAIL=

# Files and operations
FILE_STORAGE_BACKEND=s3
FILE_STORAGE_BUCKET=
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=INFO
