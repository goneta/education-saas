APP_ENV=production
APP_URL=https://teducai.com
DATABASE_URL=postgresql+psycopg2://teducai_user:CHANGE_ME@127.0.0.1:5432/teducai
CORS_ALLOWED_ORIGINS=https://teducai.com
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
FIELD_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# Security
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
AUTH_RATE_LIMIT_MAX_REQUESTS=20
MAX_REQUEST_BODY_BYTES=2097152
SESSION_IDLE_TIMEOUT_MINUTES=30
REDIS_URL=
SLOW_REQUEST_MS=1500

# Files
FILE_STORAGE_BACKEND=s3
FILE_STORAGE_BUCKET=teducai-production
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=eu-west-3
SIGNED_URL_EXPIRES_SECONDS=900
FILE_STORAGE_LOCAL_PATH=storage/uploads
MAX_UPLOAD_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.openxmlformats-officedocument.wordprocessingml.document
CLAMAV_SCAN_COMMAND="clamscan --no-summary"

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ORANGE_SMS_URL=
ORANGE_SMS_TOKEN=
ORANGE_SMS_SENDER=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
MAILGUN_DOMAIN=
MAILGUN_API_KEY=
MAILGUN_FROM_EMAIL=

# AI providers — any key present is auto-registered as an active provider at startup.
# Platform decision: OpenAI + Anthropic are PRIMARY; OpenRouter, Manus and
# Genspark are FALLBACKS (tried in that order when the primaries fail). Keys can
# also be entered in System → AI providers (stored encrypted). Balance auto-sync
# is only available for OpenRouter; the others keep a manually-entered balance.
# --- Primary providers ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
# Anthropic works out of the box (OpenAI-compatible endpoint set by default).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=
# --- Fallback providers ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Manus/Genspark serve chat only once an OpenAI-compatible *_BASE_URL (gateway/proxy) is supplied.
MANUS_API_KEY=
MANUS_MODEL=
MANUS_BASE_URL=
GENSPARK_API_KEY=
GENSPARK_MODEL=
GENSPARK_BASE_URL=
# --- Optional providers ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# xAI Grok (alias GROK_API_KEY also accepted)
XAI_API_KEY=
XAI_MODEL=grok-2-latest

# Payments
STRIPE_SECRET_KEY=
DJAMO_PAYMENT_URL=
DJAMO_API_KEY=
CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2/payment
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_NOTIFY_URL=https://teducai.com/api/platform/payments/webhook

# Backups and logs
BACKUP_DIR=/var/backups/teducai
ENCRYPT_BACKUPS=true
BACKUP_RETENTION_DAYS=30
LOG_LEVEL=INFO

# Transactional e-mail (SMTP) — invoice delivery. Gmail/Workspace defaults shown.
# For Gmail use an App Password (Google Account -> Security -> App passwords).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=TeducAI Billing
